// engine/pairing_engine_generator.js
//
// Templated pair-note generator -- food x food only (per Phase B Option C).
// Pure function: given (foodA, foodB, tier, ctx) returns a pair-note string
// in Bowdie's voice. Deterministic: same inputs always produce the same
// output, so the snapshot test stays meaningful.
//
// The generator is direction-agnostic: writing "Filet Mignon x Truffle Fries"
// produces the same text as "Truffle Fries x Filet Mignon" because we
// canonicalize internally (heavier course first). The orchestrator then
// stores the same text under both mirror keys.
//
// Vocabulary sources, in priority order:
//   1. EDITORIAL_SNIPPETS[name]   -- mined natural-language phrases
//   2. PROFILE_VOCAB[profile-tag] -- per-tag adjective phrases
//   3. raw profile words          -- fallback for unmapped tags
//
// Templated signature phrases (so engine_health_check can tell these apart
// from editorial): "carries cleanly into", "frames the cut", "into a closing",
// "stand the starter on its own", "the plate composes".
//
// Coverage check: see self-test at bottom -- runs every archetype x tier
// combination against a fixture entity and prints the output.

'use strict';

const fs = require('fs');
const vm = require('vm');
const path = require('path');
const crypto = require('crypto');

const taxonomy = require('./pairing_engine_taxonomy');

// ── COURSE WEIGHT -- canonical pair direction ──────────────────────────────
//
// When generating a pair-note, we want the "heavier" / earlier course named
// first so the prose reads naturally ("Filet Mignon alongside the truffle
// fries", not "Truffle fries alongside the filet"). This table assigns a
// weight per category; lower number = comes first in canonical order.

const CATEGORY_WEIGHT = {
  'steak': 1,
  'main': 2,
  'starter': 3,
  'soup-salad': 4,
  'side': 5,
  'dessert': 6,
};

function canonicalize(foodA, foodB) {
  const wA = CATEGORY_WEIGHT[foodA.category] || 99;
  const wB = CATEGORY_WEIGHT[foodB.category] || 99;
  if (wA <= wB) return [foodA, foodB];
  return [foodB, foodA];
}

// ── ARCHETYPE -- pair classification driving template selection ───────────

function archetypeFor(foodA, foodB) {
  // foodA / foodB already canonicalized
  const a = foodA.category, b = foodB.category;
  // Course transitions (a course earlier in the meal -> dessert)
  if (b === 'dessert' && (a === 'steak' || a === 'main')) return 'COURSE_TO_DESSERT';
  if (a === 'dessert' && b === 'dessert') return 'DESSERT_PAIR';
  // Same-course plate companions
  if (a === 'steak' && b === 'side') return 'STEAK_SIDE';
  if (a === 'main'  && b === 'side') return 'MAIN_SIDE';
  if (a === 'side'  && b === 'side') return 'SIDE_PAIR';
  // Earlier-course starters/soups against the entree
  if (a === 'steak' && b === 'starter')    return 'STEAK_STARTER';
  if (a === 'steak' && b === 'soup-salad') return 'STEAK_SOUP_SALAD';
  if (a === 'starter' && b === 'soup-salad') return 'STARTER_SOUP_SALAD';
  if (a === 'starter' && b === 'side')       return 'STARTER_SIDE';
  if (a === 'starter' && b === 'dessert')    return 'STARTER_TO_DESSERT';
  if (a === 'main' && b === 'steak')         return 'MAIN_STEAK';
  // Catch-all
  return 'GENERIC_FOOD_PAIR';
}

// ── PROFILE VOCABULARY ─────────────────────────────────────────────────────
//
// Per-profile-tag short adjective phrases used when EDITORIAL_SNIPPETS lacks
// a usable phrase. These are intentionally terse; the templates wrap them.

const PROFILE_VOCAB = {
  // Steak / meat
  'lean':         'lean cut',
  'tender':       'tender beef',
  'mild':         'mild beef',
  'buttery':      'buttery tenderness',
  'delicate':     'delicate cut',
  'bone-enhanced':'bone-enhanced richness',
  'bold':         'bold beef',
  'beefy':        'beefy character',
  'firm':         'firm grain',
  'savory':       'savory finish',
  'well-marbled': 'well-marbled cut',
  'fatty':        'fatty richness',
  'rich':         'rich body',
  'marbled':      'marbled fat',
  'bone-in':      'bone-in cut',
  'smoky':        'smoky char',
  'theatrical':   'showpiece presentation',
  'dual-texture': 'dual-texture profile',
  // Sides / starters / soups
  'umami':        'umami depth',
  'earthy':       'earthy depth',
  'indulgent':    'indulgent build',
  'creamy':       'creamy weight',
  'seafood':      'shellfish character',
  'dairy-rich':   'dairy weight',
  'crisp':        'crisp texture',
  'fresh':        'fresh body',
  'classic':      'classic build',
  'approachable': 'approachable plate',
  'manchego':     'manchego sharpness',
  'sweet':        'sweet edge',
  'crispy':       'crispy build',
  'light':        'light body',
  'seared':       'seared finish',
  'seasonal':     'seasonal plate',
  // Generic fallbacks for unrecognized tags get the raw word
};

function _profilePhrase(tag) {
  return PROFILE_VOCAB[tag] || tag;
}

// ── CURATED FOOD CHARACTER ─────────────────────────────────────────────────
//
// Per-food character phrase. Designed to slot into a template like:
//    "{A}'s {char} ..."         -> "Filet Mignon's lean buttery tenderness ..."
//    "{charA} carries cleanly..." -> "the filet's lean buttery tenderness carries..."
//
// Phrases are written WITHOUT a leading article ("the") -- the templates
// supply that when needed. Templates that need an article-prefixed form use
// a separate slot helper.
//
// EDITORIAL_SNIPPETS was tried as the source but many entries are mid-
// sentence fragments mined from drink-on-food notes (e.g. "...rounder than
// firm-tannin Napa on the"), which break standalone use. Curated table is
// 30 lines and produces clean, reliable output every time.

const FOOD_CHARACTER = {
  // Steaks
  'Filet Mignon':         'lean buttery tenderness',
  'Bone-In Filet':        'bone-enhanced buttery tenderness',
  'Kansas City':          'lean-bold strip with savory grain',
  'Cowboy Ribeye':        'marbled char-and-fat richness',
  'The Tomahawk':         'theatrical bone-in marbling and smoky char',
  'Porterhouse':          'dual strip-and-filet character',
  // Starters
  'Bone Marrow':          'unctuous rendered-marrow richness',
  'Escargot':             'garlic-herb-butter savory weight',
  'Prime Tartare':        'raw beef-and-brine umami',
  'Brussels and Belly':   'maple-pork-belly glaze over charred sprouts',
  'Crab Cake':            'delicate sweet crab in a crisp crust',
  'Shrimp Cocktail':      'cool brine-and-citrus shellfish',
  'Burrata':              'fresh basil-tomato-cream delicacy',
  'Seafood Tower':        'chilled shellfish lineup',
  // Soup / Salad
  'French Onion':         'beef-broth-and-gruyere depth',
  'Mushroom Bisque':      'silky earthy mushroom cream',
  'Gumbo':                'spiced creole stew',
  'Shrimp Bisque':        'creamy shellfish soup',
  'Loaded Potato':        'rich loaded-potato soup',
  'Clam Chowder':         'creamy clam-and-potato chowder',
  'Tomato Basil':         'bright tomato-basil acid',
  'Butternut Squash':     'silky sweet squash cream',
  'Seasonal Soup':        'house seasonal build',
  'Creamy Potato':        'silky-bodied potato soup',
  'Broccoli Cheddar':     'cheddar-and-broccoli cream',
  'Roasted Red Pepper Chickpea': 'roasted-pepper chickpea warmth',
  'Grilled Caesar':       'charred-romaine Caesar',
  'House Wedge':          'iceberg-and-bleu cool crunch',
  // Sides
  'Au Gratin Potatoes':   'cheese-and-cream golden crust',
  'Creamed Spinach':      'rich bechamel-laced greens',
  'Lobster Mac':          'shellfish-in-cream indulgence',
  'Asparagus':            'green-vegetal edge',
  'Broccolini':           'tender green broccolini',
  'Sauteed Garlic Spinach': 'garlic-buttered greens',
  'Honey Roasted Carrots':  'honey-glazed carrot sweetness',
  'Seasonal Vegetables':  'seasonal garden plate',
  'Truffle Fries':        'parmesan-and-truffle fry weight',
  'Mushrooms':            'earthy umami mushroom side',
  // Mains
  'Roast Half Chicken':   'herbed crisp-skin roast chicken',
  'Faroe Island Salmon':  'rich oily salmon flesh',
  'Swordfish':            'meaty swordfish steak',
  'Chilean Seabass':      'buttery seabass flesh',
  'Tuxedo-Crusted Yellowfin Tuna': 'seared-rare tuna with sesame crust',
  'Rainbow Trout':        'delicate trout flesh',
  'Market Fish':          'clean market-fish flesh',
  'Salt-Cured Halibut':   'salt-cured halibut',
  'Vegetable Curry with Chickpeas': 'spiced chickpea curry',
  'Seared Scallops':      'caramelized seared scallop sweetness',
  // Desserts
  'Chocolate Cake':       'layered chocolate cake',
  'Chocolate Brownie':    'fudgy chocolate brownie',
  'Peanut Butter Brownie':'peanut-butter-and-chocolate brownie',
  'Mocha Creme':          'coffee-chocolate mocha creme',
  'Creme Brulee':         'burnt-sugar custard',
  'Cheesecake':           'dense tangy dairy custard',
  'Beignets':             'warm sugar-dusted pastry',
  'Carrot Cake':          'cream-cheese-frosted carrot cake',
};

// Pull a character phrase for a food entity. Prefers the curated table;
// falls back to a 2-tag profile descriptor for any unmapped food.
function characterFor(food, snippets) {
  if (FOOD_CHARACTER[food.name]) return FOOD_CHARACTER[food.name];
  const prof = food.profile || [];
  if (prof.length >= 2) {
    return _profilePhrase(prof[0]) + ' and ' + _profilePhrase(prof[1]);
  }
  if (prof.length === 1) return _profilePhrase(prof[0]);
  return food.name.toLowerCase();
}

// ── SHORT NAME ────────────────────────────────────────────────────────────
//
// Returns the article-prefixed colloquial form of the food name -- the form
// that reads naturally in mid-sentence as a subject or possessive.
//
//    "the filet"            (Filet Mignon, mid-sentence subject)
//    "Brussels and Belly"   (proper-noun-ish dish; no article)
//    "the Tomahawk"         (proper noun + article works)
//
// Possessives are formed by appending 's, with one exception: names ending
// in 's' use just an apostrophe (Beignets' -> "the beignets'").

const SHORT_NAME = {
  // Steaks
  'Filet Mignon':         'the filet',
  'Bone-In Filet':        'the bone-in filet',
  'Kansas City':          'the KC',
  'Cowboy Ribeye':        'the cowboy ribeye',
  'The Tomahawk':         'the Tomahawk',
  'Porterhouse':          'the porterhouse',
  // Starters
  'Bone Marrow':          'the bone marrow',
  'Escargot':             'the escargot',
  'Prime Tartare':        'the tartare',
  'Brussels and Belly':   'Brussels + Belly',
  'Crab Cake':            'the crab cake',
  'Shrimp Cocktail':      'the shrimp cocktail',
  'Burrata':              'the burrata',
  'Seafood Tower':        'the seafood tower',
  // Soup / Salad
  'French Onion':         'the French onion',
  'Mushroom Bisque':      'the mushroom bisque',
  'Gumbo':                'the gumbo',
  'Shrimp Bisque':        'the shrimp bisque',
  'Loaded Potato':        'the loaded potato',
  'Clam Chowder':         'the chowder',
  'Tomato Basil':         'the tomato basil',
  'Butternut Squash':     'the butternut squash',
  'Seasonal Soup':        'the seasonal soup',
  'Creamy Potato':        'the potato soup',
  'Broccoli Cheddar':     'the broccoli cheddar',
  'Roasted Red Pepper Chickpea': 'the chickpea soup',
  'Grilled Caesar':       'the Caesar',
  'House Wedge':          'the wedge',
  // Sides
  'Au Gratin Potatoes':   'the au gratin',
  'Creamed Spinach':      'the creamed spinach',
  'Lobster Mac':          'the lobster mac',
  'Asparagus':            'the asparagus',
  'Broccolini':           'the broccolini',
  'Sauteed Garlic Spinach': 'the garlic spinach',
  'Honey Roasted Carrots':'the honey carrots',
  'Seasonal Vegetables':  'the seasonal vegetables',
  'Truffle Fries':        'the truffle fries',
  'Mushrooms':            'the mushrooms',
  // Mains
  'Roast Half Chicken':   'the chicken',
  'Faroe Island Salmon':  'the salmon',
  'Swordfish':            'the swordfish',
  'Chilean Seabass':      'the seabass',
  'Tuxedo-Crusted Yellowfin Tuna': 'the tuna',
  'Rainbow Trout':        'the trout',
  'Market Fish':          'the market fish',
  'Salt-Cured Halibut':   'the halibut',
  'Vegetable Curry with Chickpeas': 'the curry',
  'Seared Scallops':      'the scallops',
  // Desserts
  'Chocolate Cake':       'the chocolate cake',
  'Chocolate Brownie':    'the brownie',
  'Peanut Butter Brownie':'the PB brownie',
  'Mocha Creme':          'the mocha creme',
  'Creme Brulee':          'the brulee',
  'Cheesecake':           'the cheesecake',
  'Beignets':             'the beignets',
  'Carrot Cake':          'the carrot cake',
};

function shortNameFor(food) {
  return SHORT_NAME[food.name] || food.name.replace(/^The\s+/i, '').toLowerCase();
}

// Possessive form: "the filet's" / "Brussels + Belly's" / "the beignets'"
function possessiveFor(food) {
  const sn = shortNameFor(food);
  if (sn.endsWith('s')) return sn + "'";
  return sn + "'s";
}

// ── TEMPLATE LIBRARY ───────────────────────────────────────────────────────
//
// Each entry is an array of template strings. We pick deterministically
// based on a hash of the pair, so a given pair always renders the same way.
// Templates use {A}, {B} for full names; {a}, {b} for short names; {charA},
// {charB} for character phrases.

const TEMPLATES = {
  // ── STEAK x SIDE ───────────────────────────────────────────────────────
  'STEAK_SIDE.gold': [
    "{A} alongside {b} -- {aPos} {charA} carries cleanly into {bPos} {charB}. Gold standard; the side that frames the cut without overshadowing it."
  ],
  'STEAK_SIDE.excellent': [
    "{A} alongside {b} -- {aPos} {charA} carries cleanly into {bPos} {charB}. The side frames the cut at full register. Excellent; the headline side pairing for {a}.",
    "{aCap} into {b} -- {aPos} {charA} meets {bPos} {charB}. The plate composes cleanly. Excellent; reliable headline side for the steak course."
  ],
  'STEAK_SIDE.strong': [
    "{A} alongside {b} -- {aPos} {charA} sits with {bPos} {charB}. The side handles the steak's weight without competing. Strong; reliable side-on-steak match.",
    "{aCap} with {b} -- {aPos} {charA} meets {bPos} {charB} cleanly. Strong; the side carries its register against the cut."
  ],
  'STEAK_SIDE.works': [
    "{A} with {b} -- {aPos} {charA} sits alongside {bPos} {charB} without pulling focus. Works; the side call holds at neutral register.",
    "{aCap} into {b} -- {bPos} {charB} reads quietly against {aPos} {charA}. Works; safe alongside, but not the headline pick."
  ],
  'STEAK_SIDE.avoid': [
    "{aPosCap} {charA} crowds out {bPos} {charB}. Avoid; the cut overshadows the side. Save {b} for a lighter cut."
  ],

  // ── COURSE -> DESSERT (steak/main into dessert) ────────────────────────
  'COURSE_TO_DESSERT.gold': [
    "After {a}, {b} -- {aPos} {charA} gives way to {bPos} {charB}. Gold standard; the textbook close to a steak meal."
  ],
  'COURSE_TO_DESSERT.excellent': [
    "After {a}, {b} -- {aPos} {charA} gives way to {bPos} {charB}. The dessert closes the meal cleanly. Excellent; classic steak-house transition into {b}.",
    "{A} into a closing {b} -- {aPos} {charA} resolves into {bPos} {charB}. Excellent; the dessert picks up where the cut leaves off."
  ],
  'COURSE_TO_DESSERT.strong': [
    "After {a}, {b} -- {aPos} {charA} settles into {bPos} {charB}. The closer composes cleanly. Strong; reliable steak-house finish.",
    "{A} into a closing {b} -- {bPos} {charB} lands without competing with {aPos} {charA}. Strong; the dessert carries the close at full register."
  ],
  'COURSE_TO_DESSERT.works': [
    "After {a}, {b} -- {aPos} {charA} gives way to {bPos} {charB} without competing. Works; a measured close to the meal.",
    "{A} into a closing {b} -- {bPos} {charB} sits cleanly against {aPos} {charA}. Works; the close holds, neither soars nor fights."
  ],
  'COURSE_TO_DESSERT.avoid': [
    "{aPosCap} {charA} doesn't resolve into {bPos} {charB}. Avoid; the close clashes with the meal. Reach for a lighter dessert."
  ],

  // ── STEAK x STARTER (mostly avoids) ────────────────────────────────────
  'STEAK_STARTER.gold': [
    "{A} preceded by {b} -- {bPos} {charB} sets up {aPos} {charA} cleanly. Gold standard; the starter that primes the cut."
  ],
  'STEAK_STARTER.excellent': [
    "{A} preceded by {b} -- {bPos} {charB} primes the palate for {aPos} {charA}. Excellent; the starter sets up the cut at full register."
  ],
  'STEAK_STARTER.strong': [
    "{A} preceded by {b} -- {bPos} {charB} composes cleanly before {aPos} {charA}. Strong; reliable opener for the steak course."
  ],
  'STEAK_STARTER.works': [
    "{A} preceded by {b} -- {bPos} {charB} sits without crowding {aPos} {charA}. Works; the call holds, neither soars nor fights."
  ],
  'STEAK_STARTER.avoid': [
    "{aPosCap} {charA} obliterates {bPos} {charB}. Avoid; the cut is too bold for the delicate starter -- stand {b} on its own course or pair with a lighter cut.",
    "{aPosCap} {charA} overwhelms {bPos} {charB}. Avoid; the courses can't share a meal cleanly. Save {b} for a starter on a different visit."
  ],

  // ── STEAK x SOUP/SALAD ─────────────────────────────────────────────────
  'STEAK_SOUP_SALAD.excellent': [
    "{A} preceded by {b} -- {bPos} {charB} sets the table for {aPos} {charA}. Excellent; the soup-or-salad frames the steak course cleanly."
  ],
  'STEAK_SOUP_SALAD.strong': [
    "{A} into {b} -- {bPos} {charB} composes cleanly before {aPos} {charA}. Strong; reliable opener for the cut."
  ],
  'STEAK_SOUP_SALAD.works': [
    "{A} preceded by {b} -- {bPos} {charB} reads as a measured opener before {aPos} {charA}. Works; the call holds at neutral register.",
    "{A} with {b} alongside -- {bPos} {charB} sits without competing with {aPos} {charA}. Works; the side-salad call holds."
  ],
  'STEAK_SOUP_SALAD.avoid': [
    "{aPosCap} {charA} crowds out {bPos} {charB}. Avoid; the courses don't compose together. Save {b} for a lighter cut."
  ],

  // ── MAIN x SIDE ────────────────────────────────────────────────────────
  'MAIN_SIDE.excellent': [
    "{A} alongside {b} -- {aPos} {charA} carries cleanly into {bPos} {charB}. Excellent; the headline side pairing for {a}."
  ],
  'MAIN_SIDE.strong': [
    "{A} with {b} -- {aPos} {charA} meets {bPos} {charB} without competing. Strong; reliable side for the main."
  ],
  'MAIN_SIDE.works': [
    "{A} alongside {b} -- {bPos} {charB} sits quietly against {aPos} {charA}. Works; the call holds at neutral register."
  ],
  'MAIN_SIDE.avoid': [
    "{aPosCap} {charA} overwhelms {bPos} {charB}. Avoid; the side can't hold its register against the main."
  ],

  // ── MAIN x STEAK (rare) ────────────────────────────────────────────────
  'MAIN_STEAK.works': [
    "{A} alongside {b} -- two protein courses on one table. {aPosCap} {charA} sits with {bPos} {charB} without competing. Works; the meal carries two cuts cleanly."
  ],
  'MAIN_STEAK.avoid': [
    "{aPosCap} {charA} clashes with {bPos} {charB}. Avoid; the two protein courses pull in different directions. Order one or the other."
  ],

  // ── DESSERT x DESSERT ──────────────────────────────────────────────────
  'DESSERT_PAIR.works': [
    "{A} and {b} together -- {aPos} {charA} alongside {bPos} {charB}. Works; the two desserts share the close without crowding."
  ],
  'DESSERT_PAIR.avoid': [
    "{A} and {b} together overlap on the close -- {aPos} {charA} crowds out {bPos} {charB}. Avoid; pick one or the other."
  ],

  // ── STARTER -> DESSERT (rare) ──────────────────────────────────────────
  'STARTER_TO_DESSERT.works': [
    "{A} into a closing {b} -- {aPos} {charA} gives way to {bPos} {charB} after the meal. Works; the close composes without strain."
  ],
  'STARTER_TO_DESSERT.avoid': [
    "{aPosCap} {charA} doesn't carry into {bPos} {charB}. Avoid; the meal's bookends don't compose."
  ],

  // ── STARTER x SOUP/SALAD ──────────────────────────────────────────────
  'STARTER_SOUP_SALAD.works': [
    "{A} alongside {b} -- {aPos} {charA} sits with {bPos} {charB} as an opening pair. Works; the courses share the table without crowding."
  ],
  'STARTER_SOUP_SALAD.avoid': [
    "{aPosCap} {charA} clashes with {bPos} {charB}. Avoid; the opening courses don't compose together."
  ],

  // ── STARTER x SIDE ──────────────────────────────────────────────────────
  'STARTER_SIDE.works': [
    "{A} alongside {b} -- {aPos} {charA} sits with {bPos} {charB} on the same plate. Works; the call holds at neutral register."
  ],
  'STARTER_SIDE.avoid': [
    "{aPosCap} {charA} overwhelms {bPos} {charB}. Avoid; the courses can't share register."
  ],

  // ── SIDE x SIDE ────────────────────────────────────────────────────────
  'SIDE_PAIR.works': [
    "{A} and {b} together -- {aPos} {charA} sits with {bPos} {charB} on the table. Works; the two sides share the meal without competing."
  ],
  'SIDE_PAIR.avoid': [
    "{A} and {b} together overlap -- {aPos} {charA} crowds out {bPos} {charB}. Avoid; pick one side or the other."
  ],

  // ── GENERIC FOOD PAIR (catch-all) ──────────────────────────────────────
  'GENERIC_FOOD_PAIR.gold': [
    "{A} with {b} -- {aPos} {charA} carries into {bPos} {charB}. Gold standard; the pairing that defines the meal."
  ],
  'GENERIC_FOOD_PAIR.excellent': [
    "{A} with {b} -- {aPos} {charA} carries into {bPos} {charB} cleanly. Excellent; the headline call."
  ],
  'GENERIC_FOOD_PAIR.strong': [
    "{A} with {b} -- {aPos} {charA} meets {bPos} {charB}. Strong; reliable match across the courses."
  ],
  'GENERIC_FOOD_PAIR.works': [
    "{A} with {b} -- {aPos} {charA} sits alongside {bPos} {charB}. Works; the call holds at neutral register."
  ],
  'GENERIC_FOOD_PAIR.avoid': [
    "{aPosCap} {charA} clashes with {bPos} {charB}. Avoid; the courses don't share register."
  ],
};

// ── DETERMINISTIC TEMPLATE PICKER ──────────────────────────────────────────

function pickTemplate(archetype, tier, foodA, foodB) {
  const key = archetype + '.' + tier;
  let variants = TEMPLATES[key];
  if (\!variants || variants.length === 0) {
    variants = TEMPLATES['GENERIC_FOOD_PAIR.' + tier];
  }
  if (\!variants || variants.length === 0) {
    throw new Error('No template for archetype ' + archetype + ' tier ' + tier);
  }
  const sig = foodA.name + '|' + foodB.name + '|' + tier;
  const h = crypto.createHash('md5').update(sig).digest();
  const idx = h.readUInt32BE(0) % variants.length;
  return variants[idx];
}

// ── TEMPLATE FILLER ────────────────────────────────────────────────────────

function render(template, foodA, foodB, charA, charB) {
  const a = shortNameFor(foodA);
  const b = shortNameFor(foodB);
  const aPos = possessiveFor(foodA);
  const bPos = possessiveFor(foodB);
  const aCap = a.charAt(0).toUpperCase() + a.slice(1);
  const aPosCap = aPos.charAt(0).toUpperCase() + aPos.slice(1);

  return template
    .replace(/\{A\}/g, foodA.name)
    .replace(/\{B\}/g, foodB.name)
    .replace(/\{aCap\}/g, aCap)
    .replace(/\{aPosCap\}/g, aPosCap)
    .replace(/\{aPos\}/g, aPos)
    .replace(/\{bPos\}/g, bPos)
    .replace(/\{a\}/g, a)
    .replace(/\{b\}/g, b)
    .replace(/\{charA\}/g, charA)
    .replace(/\{charB\}/g, charB);
}

// ── MAIN ENTRY ─────────────────────────────────────────────────────────────

function generate(foodA, foodB, tier, ctx) {
  if (\!foodA || \!foodB) throw new Error('generate: foodA and foodB required');
  if (\!taxonomy.FOOD_CATS.has(foodA.category)) throw new Error('generate: foodA must be a food (got ' + foodA.category + ')');
  if (\!taxonomy.FOOD_CATS.has(foodB.category)) throw new Error('generate: foodB must be a food (got ' + foodB.category + ')');
  if (\!['gold','excellent','strong','works','avoid'].includes(tier)) throw new Error('generate: invalid tier ' + tier);

  const [a, b] = canonicalize(foodA, foodB);
  const archetype = archetypeFor(a, b);
  const charA = characterFor(a, ctx.EDITORIAL_SNIPPETS);
  const charB = characterFor(b, ctx.EDITORIAL_SNIPPETS);
  const template = pickTemplate(archetype, tier, a, b);
  return render(template, a, b, charA, charB);
}

module.exports = {
  generate: generate,
  archetypeFor: archetypeFor,
  characterFor: characterFor,
  canonicalize: canonicalize,
  TEMPLATES: TEMPLATES,
  FOOD_CHARACTER: FOOD_CHARACTER,
};

if (require.main === module) {
  const repoRoot = path.resolve(__dirname, '..');
  const ctx = {};
  vm.createContext(ctx);
  const load = (f, n) => vm.runInContext(fs.readFileSync(path.join(repoRoot, f), 'utf8') + '\nthis.' + n + ' = ' + n + ';', ctx);
  load('pairing-map-v2.js',     'PAIRING_MAP');
  load('enriched-profiles.js',  'ENRICHED_PROFILES');
  load('editorial-snippets.js', 'EDITORIAL_SNIPPETS');
  const byName = {};
  for (const e of ctx.PAIRING_MAP) byName[e.name] = e;

  const samples = [
    ['Filet Mignon', 'Truffle Fries', 'excellent'],
    ['Filet Mignon', 'Lobster Mac', 'excellent'],
    ['Filet Mignon', 'Creamed Spinach', 'strong'],
    ['Filet Mignon', 'House Wedge', 'works'],
    ['Filet Mignon', 'Cheesecake', 'works'],
    ['Filet Mignon', 'Beignets', 'works'],
    ['Filet Mignon', 'Chocolate Brownie', 'works'],
    ['The Tomahawk', 'Burrata', 'avoid'],
    ['The Tomahawk', 'Crab Cake', 'avoid'],
    ['Cowboy Ribeye', 'Seared Scallops', 'avoid'],
    ['Filet Mignon', 'Faroe Island Salmon', 'avoid'],
    ['Porterhouse', 'Truffle Fries', 'excellent'],
    ['Porterhouse', 'Brussels and Belly', 'strong'],
    ['Bone Marrow', 'The Tomahawk', 'excellent'],
    ['Filet Mignon', 'Beignets', 'works'],
    ['Bone-In Filet', 'Lobster Mac', 'excellent'],
    ['Kansas City', 'Truffle Fries', 'strong'],
    ['Filet Mignon', 'Shrimp Bisque', 'strong'],
  ];
  console.log('=== SAMPLE GENERATIONS ===');
  for (const [aName, bName, tier] of samples) {
    const a = byName[aName], b = byName[bName];
    if (\!a || \!b) { console.log('  ?? missing entity: ' + aName + ' or ' + bName); continue; }
    const note = generate(a, b, tier, ctx);
    const arch = archetypeFor.apply(null, canonicalize(a, b));
    console.log('');
    console.log('[' + tier.padEnd(9) + '][' + arch.padEnd(20) + '] ' + aName + ' x ' + bName);
    console.log('  ' + note);
  }
}
