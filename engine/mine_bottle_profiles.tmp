// engine/mine_bottle_profiles.js (v2 — tightened filters + ENTITY_CHARACTER fallback)
//
// Improvements over v1:
//   1. Reject character phrases < 4 words (no more "fresh dairy", "craft-blender")
//   2. Reject trivia patterns ("X% ABV", "iconic Y bottle", "Bardstown Bourbon Co")
//   3. Reject pair-context fragments (food-name leakage caught by FOOD_WORDS)
//   4. ENTITY_CHARACTER fallback when EDITORIAL_SNIPPETS is empty -- extracts
//      the character part of "Bottle's <character> handles X" sentences
//   5. Stricter standalone test: must contain at least one descriptor
//      keyword (texture/flavor/style/region word)

'use strict';

const fs = require('fs');
const vm = require('vm');
const path = require('path');

const taxonomy = require('./pairing_engine_taxonomy');

const REPO_ROOT = path.resolve(__dirname, '..');
const OUTPUT_FILE = path.join(__dirname, 'bottle_profiles_mined.js');

function loadData() {
  const ctx = {};
  vm.createContext(ctx);
  const load = (f, n) => vm.runInContext(fs.readFileSync(path.join(REPO_ROOT, f), 'utf8') + '\nthis.' + n + ' = ' + n + ';', ctx);
  load('pairing-map-v2.js',     'PAIRING_MAP');
  load('enriched-profiles.js',  'ENRICHED_PROFILES');
  load('editorial-snippets.js', 'EDITORIAL_SNIPPETS');
  load('entity-character.js',   'ENTITY_CHARACTER');
  return ctx;
}

const VERB_STARTS = /^(handles?|carries|lifts?|cuts?|frames?|wraps?|sits?|reads?|runs?|finds?|matches|softens?|rounds?|threads?|underlines?|plays?|meets?|crowds?|bulldozes|drowns?|overpowers?|overshoots?|drives?|leans?|stays?)/i;
const FOOD_WORDS = /\b(filet|steak|fries|chicken|burrata|seabass|salmon|tomahawk|brownie|cheesecake|beignets|asparagus|escargot|tuna|halibut|trout|lobster|spinach|carrots|cake|crab|shrimp|gumbo|chowder|soup|tartare|wedge|caesar|dairy)\b/i;
const INCOMPLETE_END = /\b(the|of|on|with|in|from|at|for|to|and)\s*$/i;
// Trivia patterns -- bottle facts, not character
const TRIVIA_RX = /\b(\d+%?\s*ABV|iconic|trademark|signature|company|distillery|distillers|bottling|release|edition|label\b|origin|founded|established)\b/i;
// Descriptor keywords -- the snippet must mention at least one
const DESCRIPTOR_RX = /\b(caramel|vanilla|oak|spice|honey|smoke|peat|fruit|cherry|cassis|tannin|cocoa|mocha|chocolate|coffee|citrus|orange|lemon|grapefruit|mineral|flint|earth|herb|garden|botanical|floral|toffee|nut|almond|hazelnut|sherry|wheated|rye|malt|silk|silky|velvet|crisp|bold|rich|smooth|elegant|gentle|bright|dry|sweet|bitter|brut|aged|young|cask|barrel|sherry-cask|bourbon-cask|highland|speyside|islay|napa|sonoma|chianti|barolo|brunello|pomerol|burgundy|chardonnay|sauv|sauvignon|pinot|riesling|champagne|prosecco|cava|tequila|mezcal|vodka|gin|cognac|port|amaretto|aperitivo|amaro|vermouth|absinthe|chartreuse|disaronno|frangelico|kahlua|baileys|grand marnier|chambord|honeysuckle|maritime|coastal|garrigue|grappa|menthol|warmth|register|profile)\b/i;

// Reject any snippet containing internal verbs — these are clause fragments
// that shouldn't slot into "{Bottle}'s {character} {verb} {target}".
const INTERNAL_VERBS = /\b(handles?|carries|lifts?|cuts?|frames?|wraps?|sits?|reads?|runs?|finds?|matches|softens?|rounds?|threads?|underlines?|plays?|meets?|crowds?|drowns?|overpowers?|overshoots?|drives?|leans?|stays?|grips?|complements?|mirrors?|catches?|bridges?|layers?|settles?|covers?|scales?|belongs?)\b/i;

function isStandaloneCharacter(snippet) {
  if (!snippet) return false;
  const wordCount = snippet.split(/\s+/).filter(Boolean).length;
  if (wordCount < 4) return false;
  if (snippet.length > 130) return false;
  if (VERB_STARTS.test(snippet)) return false;
  if (INTERNAL_VERBS.test(snippet)) return false;       // reject any verb anywhere
  if (/^the\b/i.test(snippet)) return false;
  if (/^this\b/i.test(snippet)) return false;            // reject "this X..." fragments
  if (FOOD_WORDS.test(snippet)) return false;
  if (INCOMPLETE_END.test(snippet)) return false;
  if (TRIVIA_RX.test(snippet)) return false;
  if (!DESCRIPTOR_RX.test(snippet)) return false;
  return true;
}

function extractTastingNotes(snippets) {
  if (!snippets || !snippets.length) return null;
  const candidates = snippets
    .filter(isStandaloneCharacter)
    .filter(s => s.includes(','))
    .sort((a, b) => b.length - a.length);
  if (!candidates.length) return null;
  const best = candidates[0];
  const parts = best.split(',').map(p => p.trim()).filter(p => p && p.length < 40 && p.length >= 3);
  if (parts.length < 2) return null;
  return parts.slice(0, 4);
}

function extractCharacter(snippets) {
  if (!snippets || !snippets.length) return null;
  const candidates = snippets
    .filter(isStandaloneCharacter)
    .filter(s => !s.includes(',') && s.length < 60)
    .sort((a, b) => a.length - b.length);
  return candidates[0] || null;
}

// ── ENTITY_CHARACTER FALLBACK ─────────────────────────────────────────────
// ENTITY_CHARACTER stores sentences that mention the bottle. Many include
// character phrases inside them: "Bottle's <character> handles X" or
// "<character> sits alongside Y at <register>". Extract the character
// fragment when EDITORIAL_SNIPPETS doesn't yield one.

function extractFromEntityCharacter(name, sentences) {
  if (!sentences || !sentences.length) return null;
  for (const item of sentences) {
    const s = (typeof item === 'string') ? item : (item.sentence || '');
    if (!s) continue;
    // Patterns:
    //   "Bottle's <character> [verb] [target]"
    //   "<character> [verb] [target] at <register>"
    // Extract the "<character>" portion (1-6 words after Bottle's, or
    // sentence start until first verb).
    const escName = name.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    let m = s.match(new RegExp(escName + "'s\\s+([\\w\\s\\-]{4,80}?)\\s+(?:handles|carries|lifts|cuts|frames|wraps|sits|reads|runs|finds|matches|softens|rounds|threads|underlines|plays|meets|crowds|drowns|overpowers|overshoots|drives|leans|stays|is|holds)", 'i'));
    if (m) {
      const char = m[1].trim();
      if (isStandaloneCharacter(char)) return char;
    }
    // Pattern: "<verdict>; <Bottle> <verb>" — skip verdict-tier sentences
  }
  return null;
}

// ── VERDICT HOOK by class + name ───────────────────────────────────────────

function deriveVerdictHook(drink, dc) {
  const name = drink.name.toLowerCase();
  if (dc === 'BOURBON_BOLD') {
    if (drink.category === 'scotch' || drink.category === 'singlemalt' ||
        /glenfiddich|glenlivet|glenmorangie|macallan|bowmore|laphroaig|lagavulin|aberlour|balvenie|cragganmore|dalmore|bruichladdich|loch lomond|glenglassaugh|johnnie walker|dewar|chivas|oban|monkey shoulder|highland|midnight/.test(name)) {
      if (/laphroaig|lagavulin|bowmore|bruichladdich/.test(name)) return 'Islay scotch';
      if (/macallan|aberlour|cragganmore|glenfiddich|glenlivet|balvenie|monkey shoulder/.test(name)) return 'Speyside scotch';
      if (/glenmorangie|dalmore|oban/.test(name)) return 'Highland scotch';
      return 'scotch';
    }
    if (drink.category === 'irish' || /jameson|tullamore|redbreast|bushmills|garavogue|dunville/.test(name)) return 'Irish whiskey';
    if (drink.category === 'japanese' || /yamazaki|hakushu|hibiki|toki|suntory|nikka/.test(name)) return 'Japanese whisky';
    if (drink.category === 'canadian' || /crown royal|canadian club|caribou crossing/.test(name)) return 'Canadian whisky';
    if (/\brye\b/.test(name) || /sazerac|pikesville|whistlepig|mammoth.*rye/.test(name)) return 'rye whiskey';
    if (/wheat|maker|weller|larceny|fitz/.test(name)) return 'wheated bourbon';
    if (/booker|stagg|cask strength/.test(name)) return 'cask-strength bourbon';
    if (/single barrel|hancock|elmer|blanton/.test(name)) return 'single-barrel bourbon';
    return 'bourbon';
  }
  if (dc === 'BIG_RED') {
    if (/cabernet|cab\b/.test(name)) return 'Napa Cab';
    if (/châteauneuf|chateauneuf|beaucastel/.test(name)) return 'Châteauneuf-du-Pape';
    if (/barolo|nebbiolo/.test(name)) return 'Barolo';
    if (/brunello/.test(name)) return 'Brunello';
    if (/bordeaux|opus/.test(name)) return 'Bordeaux blend';
    if (/zinfandel/.test(name)) return 'Zinfandel';
    return 'big red';
  }
  if (dc === 'ELEGANT_RED') {
    if (/pinot/.test(name)) return 'Pinot Noir';
    if (/chianti|sangiovese/.test(name)) return 'Chianti';
    return 'elegant red';
  }
  if (dc === 'WHITE_WINE') {
    if (/chardonnay|chard\b/.test(name)) return 'Chardonnay';
    if (/sauvignon blanc|sauv blanc/.test(name)) return 'Sauvignon Blanc';
    if (/sancerre/.test(name)) return 'Sancerre';
    if (/chablis/.test(name)) return 'Chablis';
    if (/riesling/.test(name)) return 'Riesling';
    if (/pinot blanc/.test(name)) return 'Pinot Blanc';
    return 'white wine';
  }
  if (dc === 'SPARKLING') {
    if (/champagne|brut|cuv[ée]e/.test(name)) return 'Champagne';
    if (/prosecco/.test(name)) return 'Prosecco';
    if (/cava/.test(name)) return 'Cava';
    if (/moscato/.test(name)) return 'Moscato';
    return 'sparkling';
  }
  if (dc === 'TEQUILA_BOLD') {
    if (/extra ?anejo|extra-anejo|ultra/.test(name)) return 'extra añejo tequila';
    if (/anejo/.test(name)) return 'añejo tequila';
    if (/reposado|rosa/.test(name)) return 'reposado tequila';
    return 'aged tequila';
  }
  if (dc === 'LIGHT_SPIRIT') {
    if (/blanco|silver|plata|platinum/.test(name)) return 'blanco tequila';
    if (/rum/.test(name)) return 'light rum';
    return 'light spirit';
  }
  if (dc === 'GIN') return 'gin';
  if (dc === 'VODKA')           return 'vodka';
  if (dc === 'MEZCAL')          return 'mezcal';
  if (dc === 'COGNAC')          return 'cognac';
  if (dc === 'COGNAC_LUXURY')   return 'icon cognac';
  if (dc === 'SWEET_LIQUEUR')   return 'digestif liqueur';
  if (dc === 'APERITIVO_BITTER')return 'aperitivo';
  if (dc === 'SWEET_WINE')      return 'dessert wine';
  if (dc === 'COCKTAIL_BOLD')   return 'spirit-forward cocktail';
  if (dc === 'COCKTAIL_LIGHT')  return 'light cocktail';
  if (dc === 'HEAVY_SPIRIT')    return 'heavy spirit';
  return 'pour';
}

function main() {
  const args = process.argv.slice(2);
  const dryRun = args.indexOf('--dry-run') !== -1;
  let sampleN = 0;
  const sArg = args.indexOf('--sample');
  if (sArg !== -1) sampleN = parseInt(args[sArg + 1], 10) || 10;

  const data = loadData();
  const profiles = {};
  let withTasting = 0;
  let withCharacter = 0;
  let fromEntityCharacter = 0;

  for (const e of data.PAIRING_MAP) {
    if (taxonomy.FOOD_CATS.has(e.category)) continue;
    const enrich = data.ENRICHED_PROFILES[e.name]
      ? Object.assign({}, e, { axes: data.ENRICHED_PROFILES[e.name].axes })
      : e;
    const dc = taxonomy.drinkClassFor(enrich);
    if (!dc) continue;

    const snippets = data.EDITORIAL_SNIPPETS[e.name] || [];
    let tasting = extractTastingNotes(snippets);
    let character = extractCharacter(snippets);

    // ENTITY_CHARACTER fallback for character only
    if (!character) {
      const fromEC = extractFromEntityCharacter(e.name, data.ENTITY_CHARACTER[e.name]);
      if (fromEC) {
        character = fromEC;
        fromEntityCharacter++;
      }
    }

    const verdictHook = deriveVerdictHook(e, dc);

    if (!tasting && !character) continue;
    if (tasting) withTasting++;
    if (character) withCharacter++;

    profiles[e.name] = {
      tastingNotes: tasting,
      character: character,
      verdictHook: verdictHook,
    };
  }

  console.log('=== mine_bottle_profiles (v2) ===');
  console.log('profiles mined:                   ' + Object.keys(profiles).length);
  console.log('  with tasting notes:             ' + withTasting);
  console.log('  with character:                 ' + withCharacter);
  console.log('  character from ENTITY_CHARACTER:' + fromEntityCharacter);
  console.log('');

  if (sampleN) {
    const keys = Object.keys(profiles).slice(0, sampleN);
    console.log('Sample profiles:');
    for (const k of keys) {
      console.log('  ' + k);
      console.log('    tastingNotes: ' + (profiles[k].tastingNotes ? JSON.stringify(profiles[k].tastingNotes) : 'null'));
      console.log('    character:    ' + (profiles[k].character || 'null'));
      console.log('    verdictHook:  ' + profiles[k].verdictHook);
    }
    console.log('');
  }

  if (dryRun) { console.log('[DRY-RUN] no files modified.'); return; }

  const lines = [];
  lines.push('// AUTO-GENERATED by engine/mine_bottle_profiles.js -- do not edit by hand.');
  lines.push('const BOTTLE_PROFILES_MINED = {');
  const keys = Object.keys(profiles).sort();
  for (const k of keys) {
    const p = profiles[k];
    lines.push('  ' + JSON.stringify(k) + ': {